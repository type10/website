---
import { alternatesFor, publicUrl, ogLocale, otherLocale } from '../i18n/routes';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  sub?: string;
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
}

const {
  locale,
  routeKey,
  sub,
  title,
  description,
  ogImage = '/assets/logo/logo-opengraph.png',
  noindex = false,
  type = 'website',
} = Astro.props;

const canonical = publicUrl(routeKey, locale, sub);
const alt = alternatesFor(routeKey, sub);
const ogImageUrl = new URL(ogImage, canonical).href;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="en" href={alt.en} />
<link rel="alternate" hreflang="de" href={alt.de} />
<link rel="alternate" hreflang="x-default" href={alt['x-default']} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={type} />
<meta property="og:site_name" content="TYPE10 Media" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content={ogLocale[locale]} />
<meta property="og:locale:alternate" content={ogLocale[otherLocale(locale)]} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:site" content="@type10media" />
