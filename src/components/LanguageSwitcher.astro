---
import { publicUrl, otherLocale } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  sub?: string;
}
const { locale, routeKey, sub } = Astro.props;
const target = otherLocale(locale);
// Cross-domain absolute URL to the equivalent page in the other language.
const href = publicUrl(routeKey, target, sub);
const t = useTranslations(locale);

// English (type10.com, international) → GB flag; German (type10.de) → DE flag.
const flag: Record<Locale, string> = { en: 'gb', de: 'de' };
---

<a class="lang-switch" href={href} hreflang={target} lang={target} rel="alternate">
  <img class="flag" src={`/assets/flags/${flag[target]}.svg`} alt="" width="20" height="14" />
  <span aria-hidden="true">{target.toUpperCase()}</span>
  <span class="visually-hidden">{t('lang.switch')}</span>
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--ink-700);
    border: 1.5px solid var(--line-strong);
    border-radius: var(--radius-sm);
    padding: 0.4em 0.7em;
    line-height: 1;
  }
  .lang-switch:hover {
    text-decoration: none;
    border-color: var(--brand);
    color: var(--brand);
  }
  .flag {
    width: 20px;
    height: 14px;
    border-radius: 2px;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
</style>
