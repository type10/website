---
interface Props {
  heading: string;
}
const { heading } = Astro.props;

// Recognisable clients/partners from the migrated asset set.
const logos = [
  { file: 'autoscout24.png', alt: 'AutoScout24' },
  { file: 'check24.png', alt: 'CHECK24' },
  { file: 'maxdome.png', alt: 'maxdome' },
  { file: 'rtl.png', alt: 'RTL' },
  { file: 'p7s1.png', alt: 'ProSiebenSat.1' },
  { file: 'lusini.png', alt: 'Lusini' },
  { file: '1und1.png', alt: '1&1' },
  { file: 'songpier.png', alt: 'Songpier' },
];
---

<section class="section-tight logowall">
  <div class="container">
    <p class="logowall-heading">{heading}</p>
    <ul class="logos">
      {
        logos.map((l) => (
          <li>
            <img
              src={`/assets/customers/${l.file}`}
              alt={l.alt}
              loading="lazy"
              decoding="async"
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .logowall-heading {
    text-align: center;
    font-size: var(--step--1);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-500);
    margin-bottom: var(--space-4);
  }
  .logos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-3) clamp(1.25rem, 2.5vw, 2.25rem);
  }
  /* Uniform cells: each logo scales to fit, so wide wordmarks and square marks
     share a consistent, generous footprint. */
  .logos li {
    display: flex;
    align-items: center;
    justify-content: center;
    height: clamp(80px,10.5vw,100px);
  }
  .logos img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.55);
    transition: filter 0.2s ease;
  }
  .logos img:hover {
    filter: grayscale(0) opacity(1);
  }
</style>
