---
import { getCollection, render } from 'astro:content';
import PageHeader from '../PageHeader.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import CTA from '../CTA.astro';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';
import { SOCIAL_ICON_PATHS } from '../../lib/socialIcons';
import type { Locale } from '../../i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const members = (await getCollection('team', (e) => e.data.locale === locale)).sort(
  (a, b) => a.data.order - b.data.order
);
const rendered = await Promise.all(
  members.map(async (m) => ({ data: m.data, Content: (await render(m)).Content }))
);

const copy = {
  en: {
    eyebrow: 'Team',
    title: 'The face behind TYPE10',
    lead: 'Deliberately small, deliberately senior. The person you talk to is the person who gets the work done and the network coordinated.',
    profile: 'Skill profile (PDF)',
    networkEyebrow: 'Our network',
    networkTitle: 'A senior core, backed by a trusted network',
    networkBody:
      'When a project needs more hands or a specific specialism, we draw on a proven network of senior freelancers across the stack — frontend, backend, infrastructure, data and design. TYPE10 stays your single point of accountability: we pick the right people, brief them, and own the delivery from first commit to handover.',
  },
  de: {
    eyebrow: 'Team',
    title: 'Das Gesicht hinter TYPE10',
    lead: 'Bewusst klein, bewusst erfahren. Die Person, mit der Sie sprechen, ist die Person, die die Arbeit erledigt und das Netzwerk koordiniert.',
    profile: 'Skill-Profil (PDF)',
    networkEyebrow: 'Unser Netzwerk',
    networkTitle: 'Ein erfahrener Kern, gestützt von einem vertrauten Netzwerk',
    networkBody:
      'Wenn ein Projekt mehr Hände oder ein bestimmtes Spezialgebiet braucht, greifen wir auf ein bewährtes Netzwerk erfahrener Freelancer über den gesamten Stack zurück — Frontend, Backend, Infrastruktur, Daten und Design. TYPE10 bleibt Ihr zentraler Ansprechpartner: Wir wählen die richtigen Leute aus, briefen sie und verantworten die Lieferung vom ersten Commit bis zur Übergabe.',
  },
}[locale];
---

<PageHeader eyebrow={copy.eyebrow} title={copy.title} lead={copy.lead}>
  <Breadcrumbs
    slot="breadcrumbs"
    locale={locale}
    items={[
      { label: t('breadcrumb.home'), href: localizedPath('home', locale) },
      { label: t('nav.team') },
    ]}
  />
</PageHeader>

<section class="section">
  <div class="container container-narrow">
    {
      rendered.map(({ data, Content }) => (
        <article class="member">
          <header class="member-head">
            {data.image && (
              <img class="member-photo" src={data.image} alt={data.name} width="320" height="320" />
            )}
            <div class="member-id">
              <h2>{data.name}</h2>
              <p class="role">{data.jobtitle}</p>
              <ul class="social">
                {[
                  { label: 'GitHub', href: data.links.github, path: SOCIAL_ICON_PATHS.github },
                  { label: 'LinkedIn', href: data.links.linkedin, path: SOCIAL_ICON_PATHS.linkedin },
                  { label: 'XING', href: data.links.xing, path: SOCIAL_ICON_PATHS.xing },
                  { label: 'X', href: data.links.twitter, path: SOCIAL_ICON_PATHS.x },
                ]
                  .filter((s) => s.href)
                  .map((s) => (
                    <li>
                      <a href={s.href} aria-label={s.label} rel="noopener" target="_blank">
                        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
                          <path fill="currentColor" d={s.path} />
                        </svg>
                      </a>
                    </li>
                  ))}
              </ul>
              {data.skillProfile && (
                <a class="btn btn-ghost" href={data.skillProfile} target="_blank" rel="noopener">{copy.profile}</a>
              )}
            </div>
          </header>
          <div class="member-bio prose">
            <Content />
          </div>
        </article>
      ))
    }
  </div>
</section>

<section class="section surface-alt">
  <div class="container container-narrow">
    <span class="eyebrow">{copy.networkEyebrow}</span>
    <h2>{copy.networkTitle}</h2>
    <p class="muted">{copy.networkBody}</p>
  </div>
</section>

<CTA
  heading={t('cta.heading')}
  text={t('cta.text')}
  buttonLabel={t('cta.contact')}
  buttonHref={localizedPath('contact', locale)}
/>

<style>
  .member + .member {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--line);
  }
  .member-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 560px) {
    .member-head {
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
    }
  }
  .member-photo {
    flex: none;
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid var(--line);
  }
  .member-id h2 {
    font-size: var(--step-2);
  }
  .role {
    color: var(--brand);
    font-weight: 600;
    margin-top: var(--space-1);
    margin-bottom: var(--space-2);
  }
  .social {
    list-style: none;
    margin: 0 0 var(--space-3);
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .social a {
    display: inline-flex;
    padding: 0.4rem;
    margin: -0.4rem;
    color: var(--ink-500);
    border-radius: var(--radius);
    transition: color 0.15s ease;
  }
  .social a:hover,
  .social a:focus-visible {
    color: var(--brand);
  }
  .social svg {
    display: block;
  }
</style>
