---
import { getCollection } from 'astro:content';
import PageHeader from '../PageHeader.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import ServiceCard from '../ServiceCard.astro';
import CTA from '../CTA.astro';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const services = (await getCollection('services', (e) => e.data.locale === locale)).sort(
  (a, b) => a.data.order - b.data.order
);

const copy = {
  en: {
    eyebrow: 'What we do',
    title: 'Services',
    lead: 'Five focused practices, one senior team. We embed with your engineers or run delivery end to end.',
  },
  de: {
    eyebrow: 'Was wir tun',
    title: 'Leistungen',
    lead: 'Fünf fokussierte Disziplinen, ein erfahrenes Team. Wir verstärken Ihre Entwickler:innen oder übernehmen die Umsetzung komplett.',
  },
}[locale];
---

<PageHeader eyebrow={copy.eyebrow} title={copy.title} lead={copy.lead}>
  <Breadcrumbs
    slot="breadcrumbs"
    locale={locale}
    items={[
      { label: t('breadcrumb.home'), href: localizedPath('home', locale) },
      { label: t('nav.services') },
    ]}
  />
</PageHeader>

<section class="section">
  <div class="container">
    <div class="grid grid-3">
      {services.map((s) => <ServiceCard locale={locale} entry={s} />)}
    </div>
  </div>
</section>

<CTA
  heading={t('cta.heading')}
  text={t('cta.text')}
  buttonLabel={t('cta.contact')}
  buttonHref={localizedPath('contact', locale)}
/>
