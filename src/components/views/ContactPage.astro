---
import PageHeader from '../PageHeader.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import { company } from '../../i18n/site';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const copy = {
  en: {
    eyebrow: 'Contact',
    title: 'Get in touch',
    lead: "Tell us about your platform, your roadmap or the team you're scaling — we reply within a working day.",
    intro: "The fastest way to reach us is email. Prefer a call? Use the number below and we'll find a time.",
    emailCta: 'Email us',
    office: 'Office',
    phone: 'Phone',
  },
  de: {
    eyebrow: 'Kontakt',
    title: 'Kontakt aufnehmen',
    lead: 'Erzählen Sie uns von Ihrer Plattform, Ihrer Roadmap oder dem Team, das Sie skalieren — wir antworten innerhalb eines Werktags.',
    intro: 'Am schnellsten erreichen Sie uns per E-Mail. Lieber telefonieren? Nutzen Sie die Nummer unten, wir finden einen Termin.',
    emailCta: 'E-Mail schreiben',
    office: 'Büro',
    phone: 'Telefon',
  },
}[locale];
---

<PageHeader eyebrow={copy.eyebrow} title={copy.title} lead={copy.lead}>
  <Breadcrumbs
    slot="breadcrumbs"
    locale={locale}
    items={[
      { label: t('breadcrumb.home'), href: localizedPath('home', locale) },
      { label: t('nav.contact') },
    ]}
  />
</PageHeader>

<section class="section">
  <div class="container contact-grid">
    <div class="contact-card">
      <h2>{copy.office}</h2>
      <address>
        {company.legalName}<br />
        {company.address.street}<br />
        {company.address.postalCode} {company.address.city}
      </address>
      <dl>
        <dt>E-Mail</dt>
        <dd><a href={`mailto:${company.email}`}>{company.email}</a></dd>
        <dt>{copy.phone}</dt>
        <dd><a href={`tel:${company.phoneE164}`}>{company.phone}</a></dd>
        <dt>Fax</dt>
        <dd>{company.fax}</dd>
      </dl>
    </div>
    <div class="contact-intro">
      <p class="lead">{copy.intro}</p>
      <a class="btn btn-primary" href={`mailto:${company.email}`}>{copy.emailCta}</a>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-5);
    align-items: start;
  }
  @media (min-width: 760px) {
    .contact-grid {
      grid-template-columns: 320px minmax(0, 1fr);
    }
  }
  .contact-card {
    background: var(--paper-alt);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  .contact-card h2 {
    font-size: var(--step-1);
    margin-bottom: var(--space-2);
  }
  .contact-card address {
    font-style: normal;
    line-height: 1.8;
    margin-bottom: var(--space-3);
  }
  .contact-card dl {
    display: grid;
    gap: 0.4em;
    margin: 0;
  }
  .contact-card dt {
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-500);
  }
  .contact-card dd {
    margin: 0 0 var(--space-2);
  }
</style>
