---
import { getCollection } from 'astro:content';
import PageHeader from '../PageHeader.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import TopicCard from '../TopicCard.astro';
import CTA from '../CTA.astro';
import { localizedPath } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const items = (await getCollection('technologies', (e) => e.data.locale === locale)).sort(
  (a, b) => a.data.order - b.data.order
);

const copy = {
  en: {
    eyebrow: 'Technologies',
    title: 'The tools we reach for',
    lead: "The technologies we've used in production for years — and where they've earned their place.",
  },
  de: {
    eyebrow: 'Technologien',
    title: 'Die Werkzeuge, zu denen wir greifen',
    lead: 'Die Technologien, die wir seit Jahren produktiv einsetzen — und wo sie sich bewährt haben.',
  },
}[locale];
---

<PageHeader eyebrow={copy.eyebrow} title={copy.title} lead={copy.lead}>
  <Breadcrumbs
    slot="breadcrumbs"
    locale={locale}
    items={[
      { label: t('breadcrumb.home'), href: localizedPath('home', locale) },
      { label: t('nav.technologies') },
    ]}
  />
</PageHeader>

<section class="section">
  <div class="container">
    <div class="grid grid-2">
      {
        items.map((i) => (
          <TopicCard
            href={localizedPath('technologies', locale, i.data.slug)}
            title={i.data.title}
            summary={i.data.summary}
          />
        ))
      }
    </div>
  </div>
</section>

<CTA
  heading={t('cta.heading')}
  text={t('cta.text')}
  buttonLabel={t('cta.contact')}
  buttonHref={localizedPath('contact', locale)}
/>
