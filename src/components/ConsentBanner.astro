---
import { localizedPath } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import { CONSENT_REQUIRED_REGIONS as regions } from '../i18n/consent';
import type { Locale } from '../i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const copy = {
  en: {
    text: 'We use cookies for analytics — only with your consent.',
    accept: 'Accept',
    decline: 'Decline',
  },
  de: {
    text: 'Wir verwenden Cookies zur Analyse — nur mit Ihrer Einwilligung.',
    accept: 'Akzeptieren',
    decline: 'Ablehnen',
  },
}[locale];
const privacyHref = localizedPath('privacy', locale);
---

<div id="t10-consent" class="consent" role="dialog" aria-label="Cookie consent" hidden>
  <p>{copy.text} <a href={privacyHref}>{t('nav.privacy')}</a></p>
  <div class="consent-actions">
    <button type="button" id="t10-decline" class="btn btn-ghost">{copy.decline}</button>
    <button type="button" id="t10-accept" class="btn btn-primary">{copy.accept}</button>
  </div>
</div>

<script is:inline define:vars={{ regions }}>
  // Drives Google Consent Mode for the GTM containers (see Gtm.astro), which sets the
  // defaults before GTM loads. The banner is shown ONLY in consent-required regions
  // (EEA + UK + CH); elsewhere analytics is granted by the region default and no banner
  // appears. Region comes from Cloudflare's edge trace; if it can't be determined
  // (incl. local/preview) the visitor is treated as restricted so we never under-ask.
  (function () {
    var KEY = 't10_consent';
    var el = document.getElementById('t10-consent');
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      window.dataLayer.push(arguments);
    }
    function get() {
      try {
        return localStorage.getItem(KEY);
      } catch (e) {
        return null;
      }
    }
    function set(v) {
      try {
        localStorage.setItem(KEY, v);
      } catch (e) {}
    }
    function choose(value) {
      set(value);
      gtag('consent', 'update', { analytics_storage: value });
      window.dataLayer.push({ event: 'consent_update', analytics_consent: value });
      if (el) el.hidden = true;
    }
    var a = document.getElementById('t10-accept');
    var d = document.getElementById('t10-decline');
    if (a) a.addEventListener('click', function () { choose('granted'); });
    if (d) d.addEventListener('click', function () { choose('denied'); });

    // Already decided → never show again (Gtm.astro re-applied the choice in <head>).
    var c = get();
    if (c === 'granted' || c === 'denied') return;

    // Otherwise show the banner only in consent-required regions.
    function inRestrictedRegion(cb) {
      var cached = null;
      try {
        cached = sessionStorage.getItem('t10_geo');
      } catch (e) {}
      if (cached) {
        cb(regions.indexOf(cached) !== -1);
        return;
      }
      fetch('/cdn-cgi/trace')
        .then(function (r) {
          return r.text();
        })
        .then(function (txt) {
          var m = txt.match(/(?:^|\n)loc=([A-Z]{2})/);
          var loc = m ? m[1] : '';
          try {
            if (loc) sessionStorage.setItem('t10_geo', loc);
          } catch (e) {}
          cb(loc ? regions.indexOf(loc) !== -1 : true); // unknown → restricted (safe)
        })
        .catch(function () {
          cb(true); // trace unavailable (e.g. local/preview) → restricted (safe)
        });
    }

    inRestrictedRegion(function (restricted) {
      if (restricted && el) el.hidden = false;
      // Rest of the world: leave hidden; analytics is granted by the region default.
    });
  })();
</script>

<style>
  .consent {
    position: fixed;
    inset: auto var(--space-3) var(--space-3) var(--space-3);
    max-width: 540px;
    margin-inline: auto;
    z-index: 80;
    background: var(--paper);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    box-shadow: var(--shadow-2);
    padding: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .consent[hidden] {
    display: none;
  }
  .consent p {
    font-size: var(--step--1);
    margin: 0;
    flex: 1 1 240px;
  }
  .consent-actions {
    display: flex;
    gap: var(--space-2);
  }
  .consent .btn {
    padding: 0.6em 1.1em;
  }
</style>
