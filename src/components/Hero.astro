---
interface Cta {
  label: string;
  href: string;
}
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  primary: Cta;
  secondary?: Cta;
}
const { eyebrow, title, lead, primary, secondary } = Astro.props;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <span class="blob blob-1"></span>
    <span class="blob blob-2"></span>
    <span class="blob blob-3"></span>
    <span class="hero-grid"></span>
  </div>
  <div class="container hero-inner">
    <span class="eyebrow">{eyebrow}</span>
    <h1 set:html={title} />
    <p class="lead">{lead}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={primary.href}>{primary.label}</a>
      {secondary && <a class="btn btn-ghost" href={secondary.href}>{secondary.label}</a>}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, var(--paper) 0%, var(--paper-alt) 100%);
    padding-block: clamp(var(--space-6), 6vw + 2rem, var(--space-8));
  }

  /* ---- background: drifting brand blobs behind a faint technical grid ---- */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    will-change: transform;
  }
  .blob-1 {
    width: 36rem;
    height: 36rem;
    left: -10%;
    top: -45%;
    background: radial-gradient(circle, rgba(115, 65, 180, 0.5), transparent 70%);
    animation: drift-1 22s ease-in-out infinite alternate;
  }
  .blob-2 {
    width: 30rem;
    height: 30rem;
    right: -8%;
    top: -35%;
    background: radial-gradient(circle, rgba(99, 195, 209, 0.45), transparent 70%);
    animation: drift-2 27s ease-in-out infinite alternate;
  }
  .blob-3 {
    width: 26rem;
    height: 26rem;
    left: 40%;
    top: 5%;
    background: radial-gradient(circle, rgba(162, 121, 210, 0.35), transparent 70%);
    animation: drift-3 31s ease-in-out infinite alternate;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(115, 65, 180, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(115, 65, 180, 0.07) 1px, transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(115% 85% at 50% 0%, #000 38%, transparent 78%);
    mask-image: radial-gradient(115% 85% at 50% 0%, #000 38%, transparent 78%);
  }

  @keyframes drift-1 {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(60px, 40px, 0) scale(1.12);
    }
  }
  @keyframes drift-2 {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-50px, 36px, 0) scale(1.06);
    }
  }
  @keyframes drift-3 {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(34px, -28px, 0) scale(1.1);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none;
    }
  }

  /* ---- foreground ---- */
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
  }
  .hero h1 {
    margin-bottom: var(--space-3);
  }
  .hero h1 :global(.hl) {
    background: linear-gradient(120deg, var(--brand) 30%, var(--accent-600));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero .lead {
    margin-bottom: var(--space-4);
    max-width: 54ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
