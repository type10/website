---
interface Cta {
  label: string;
  href: string;
}
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  primary: Cta;
  secondary?: Cta;
}
const { eyebrow, title, lead, primary, secondary } = Astro.props;
---

<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container hero-inner">
    <span class="eyebrow">{eyebrow}</span>
    <h1 set:html={title} />
    <p class="lead">{lead}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={primary.href}>{primary.label}</a>
      {secondary && <a class="btn btn-ghost" href={secondary.href}>{secondary.label}</a>}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, var(--paper) 0%, var(--paper-alt) 100%);
    padding-block: clamp(var(--space-6), 6vw + 2rem, var(--space-8));
  }
  .hero-glow {
    position: absolute;
    inset: -30% 30% auto -10%;
    height: 60vh;
    background: radial-gradient(
        50% 50% at 20% 20%,
        rgba(115, 65, 180, 0.18),
        transparent 70%
      ),
      radial-gradient(40% 40% at 80% 10%, rgba(99, 195, 209, 0.18), transparent 70%);
    filter: blur(10px);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    max-width: 56rem;
  }
  .hero h1 {
    margin-bottom: var(--space-3);
  }
  .hero h1 :global(.hl) {
    background: linear-gradient(120deg, var(--brand) 30%, var(--accent-600));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero .lead {
    margin-bottom: var(--space-4);
    max-width: 54ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
