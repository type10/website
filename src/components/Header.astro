---
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localizedPath } from '../i18n/routes';
import { useTranslations, navItems } from '../i18n/ui';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  sub?: string;
}
const { locale, routeKey, sub } = Astro.props;
const t = useTranslations(locale);
---

<header class="site-header">
  <div class="container bar">
    <a href={localizedPath('home', locale)} class="brand" aria-label="TYPE10 Media — home">
      <Logo />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav" aria-label="Primary">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={localizedPath(item.route, locale)}
                aria-current={item.route === routeKey ? 'page' : undefined}
              >
                {t(item.key)}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="nav-actions">
        <LanguageSwitcher locale={locale} routeKey={routeKey} sub={sub} />
        <a class="btn btn-primary" href={localizedPath('contact', locale)}>{t('cta.contact')}</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 68px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav a {
    color: var(--ink-700);
    font-weight: 500;
    font-size: var(--step--1);
  }
  .nav a:hover,
  .nav a[aria-current='page'] {
    color: var(--brand);
    text-decoration: none;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* mobile menu (CSS only) */
  .nav-toggle,
  .hamburger {
    display: none;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
  }
  .hamburger span + span {
    margin-top: 5px;
  }

  @media (max-width: 900px) {
    .hamburger {
      display: inline-block;
      cursor: pointer;
      padding: 8px;
    }
    .nav {
      position: absolute;
      inset: 68px 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-3);
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      padding: var(--space-3);
      box-shadow: var(--shadow-2);
      display: none;
    }
    .nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }
    .nav ul li {
      padding-block: 0.5rem;
      border-bottom: 1px solid var(--line);
    }
    .nav-actions {
      justify-content: space-between;
      margin-top: var(--space-2);
    }
    .nav-toggle:checked ~ .nav {
      display: flex;
    }
  }
</style>
