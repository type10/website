---
import '@fontsource-variable/inter';
import '@fontsource/sansation/400.css';
import '@fontsource/sansation/700.css';
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Organization from '../components/Schema/Organization.astro';
import WebSite from '../components/Schema/WebSite.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  sub?: string;
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
}

const { locale, routeKey, sub, title, description, ogImage, noindex, type } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <Seo
      locale={locale}
      routeKey={routeKey}
      sub={sub}
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      type={type}
    />
    <Organization locale={locale} />
    <WebSite locale={locale} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">{locale === 'de' ? 'Zum Inhalt springen' : 'Skip to content'}</a>
    <Header locale={locale} routeKey={routeKey} sub={sub} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <ConsentBanner locale={locale} />
  </body>
</html>
