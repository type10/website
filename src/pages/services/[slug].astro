---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ServiceDetail from '../../components/views/ServiceDetail.astro';

export async function getStaticPaths() {
  const items = await getCollection('services', (e) => e.data.locale === 'en');
  return items.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const title = d.seo?.title ?? `${d.title} — TYPE10 Media`;
---

<Base
  locale="en"
  routeKey="services"
  sub={d.slug}
  title={title}
  description={d.seo?.description ?? d.summary}
  ogImage={d.seo?.ogImage}
>
  <ServiceDetail locale="en" entry={entry} />
</Base>
