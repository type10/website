{
  "name": "type10-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "preview:cf": "astro build && wrangler pages dev dist --compatibility-date=2024-05-01 --port 8788",
    "check": "astro check",
    "check:seo": "npm run build && node scripts/check-seo.mjs",
